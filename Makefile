# =============================================================================
# Go 언어 학습 프로젝트 Makefile
# =============================================================================
# 사용법: make [target]
# 예시:
#   make build          - Docker 이미지 빌드
#   make up             - 컨테이너 시작
#   make shell          - 컨테이너 접속
#   make run CH=ch01_hello_go FILE=main.go  - 특정 챕터 실행
# =============================================================================

.PHONY: help build up shell down run test clean fmt vet

# 기본 타겟: help
.DEFAULT_GOAL := help

# 컨테이너 이름
CONTAINER := go-edu-container

# -----------------------------------------------------------------------------
# help: 사용 가능한 모든 명령어를 출력한다
# -----------------------------------------------------------------------------
help:
	@echo ""
	@echo "======================================"
	@echo "  Go 언어 학습 프로젝트 - 명령어 목록"
	@echo "======================================"
	@echo ""
	@echo "  make build          Docker 이미지를 빌드한다"
	@echo "  make up             컨테이너를 백그라운드로 시작한다"
	@echo "  make shell          실행 중인 컨테이너에 bash로 접속한다"
	@echo "  make down           컨테이너를 중지하고 제거한다"
	@echo "  make run CH=<챕터> FILE=<파일>  특정 챕터의 Go 파일을 실행한다"
	@echo "  make test CH=<챕터>             특정 챕터의 테스트를 실행한다"
	@echo "  make clean          컨테이너와 이미지를 모두 제거한다"
	@echo "  make fmt            모든 Go 파일에 go fmt를 실행한다"
	@echo "  make vet            모든 Go 파일에 go vet를 실행한다"
	@echo ""
	@echo "예시:"
	@echo "  make run CH=ch01_hello_go FILE=main.go"
	@echo "  make run CH=ch05_functions FILE=basic.go"
	@echo "  make test CH=ch26_testing"
	@echo ""

# -----------------------------------------------------------------------------
# build: Docker 이미지를 빌드한다
# -----------------------------------------------------------------------------
build:
	docker compose build

# -----------------------------------------------------------------------------
# up: 컨테이너를 백그라운드로 시작한다
# -----------------------------------------------------------------------------
up:
	docker compose up -d

# -----------------------------------------------------------------------------
# shell: 실행 중인 컨테이너에 bash로 접속한다
# -----------------------------------------------------------------------------
shell:
	docker exec -it $(CONTAINER) bash

# -----------------------------------------------------------------------------
# down: 컨테이너를 중지하고 제거한다
# -----------------------------------------------------------------------------
down:
	docker compose down

# -----------------------------------------------------------------------------
# run: 특정 챕터의 Go 파일을 실행한다
# 사용법: make run CH=ch01_hello_go FILE=main.go
# FILE을 생략하면 main.go를 실행한다
# -----------------------------------------------------------------------------
run:
ifndef CH
	@echo "오류: CH(챕터)를 지정해야 한다."
	@echo "사용법: make run CH=ch01_hello_go FILE=main.go"
	@exit 1
endif
	docker exec -it $(CONTAINER) bash /workspace/scripts/run_chapter.sh $(CH) $(FILE)

# -----------------------------------------------------------------------------
# test: 특정 챕터의 테스트를 실행한다
# 사용법: make test CH=ch26_testing
# -----------------------------------------------------------------------------
test:
ifndef CH
	@echo "오류: CH(챕터)를 지정해야 한다."
	@echo "사용법: make test CH=ch26_testing"
	@exit 1
endif
	docker exec -it $(CONTAINER) go test -v ./$(CH)/...

# -----------------------------------------------------------------------------
# clean: 컨테이너와 이미지를 모두 제거한다
# -----------------------------------------------------------------------------
clean:
	docker compose down --rmi all --volumes --remove-orphans

# -----------------------------------------------------------------------------
# fmt: 모든 Go 파일에 go fmt를 실행한다
# -----------------------------------------------------------------------------
fmt:
	docker exec -it $(CONTAINER) go fmt ./...

# -----------------------------------------------------------------------------
# vet: 모든 Go 파일에 go vet를 실행한다
# -----------------------------------------------------------------------------
vet:
	docker exec -it $(CONTAINER) go vet ./...
